{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "conda run --no-capture-output -n Noh_Base_BE python .claude/hooks/stop_gate.py"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(conda run:*)",
      "Bash(ruff:*)",
      "Bash(mypy:*)",
      "Bash(pytest:*)",
      "Bash(python:*)",
      "Bash(pip:*)",
      "Bash(uvicorn:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git add:*)",
      "Bash(git log:*)",
      "Bash(git show:*)"
    ],
    "deny": []
  }
}
