# 앱 설정 (실제 값은 .env 에 작성 — .env 는 커밋 금지)
APP_ENV=local
APP_NAME="Noh-Base-BE"

# Firebase Admin SDK
# 서비스 계정 키 JSON 파일 경로 (로컬). 운영에서는 GOOGLE_APPLICATION_CREDENTIALS 또는 워크로드 ID 사용
FIREBASE_CREDENTIALS_PATH=./serviceAccountKey.json
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_STORAGE_BUCKET=your-firebase-project-id.appspot.com

# LLM 폴백 (DB 미수록 의학용어 처리용) — 사용 모델 키
LLM_API_KEY=

# 무료 요금제 기본 한도 (변환 횟수 = 비용 동인 기준)
FREE_MONTHLY_CONVERSIONS=5
